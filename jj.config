[ui]
default-command = "status"
diff-formatter = ["difft", "--color=always", "$left", "$right"]

diff-editor = ":builtin"
merge-editor = "mergiraf"

[revsets]
log = "(trunk()..@):: | (trunk()..@)-"

[revset-aliases]
"closest_bookmark(to)" = "latest(heads(::to & bookmarks()))"
"default()" = "coalesce(trunk(),root())::present(@) | ancestors(visible_heads() & recent(), 25)"
"recent()" = "committer_date(after:'1 month ago')"
"authored()" = "author(regex:'.*@.*')"
"full()" = "ancestors(coalesce(trunk(),root())::present(@))"

[aliases]
logg = ["log", "-r", "connected(default() & recent()) & authored()"]
logf = ["log", "-r", "full() & authored()", "--template", "builtin_log_detailed"]

edit- = ["edit", "-r", "@-"]
show- = ["show", "-r", "@-"]
diff- = ["diff", "-r", "@-"]
desc- = ["describe", "-r", "@-"]

now = ["metaedit", "--update-author-timestamp", "-r", "@"]
now- = ["metaedit", "--update-author-timestamp", "-r", "@-"]

tug  = ["bookmark", "move", "--from", "closest_bookmark(@)",  "--to", "@" ]
tug- = ["bookmark", "move", "--from", "closest_bookmark(@-)", "--to", "@-"]

retrunk = ["rebase", "--onto", "trunk()"]
